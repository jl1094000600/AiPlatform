# Copy this file to deploy/.env before running Docker Compose.
MYSQL_ROOT_PASSWORD=change-me-root
MYSQL_USER=ai_app
MYSQL_PASSWORD=change-me-app
MYSQL_PORT=3306

REDIS_PASSWORD=change-me-redis
REDIS_PORT=6379

BACKEND_IMAGE=ai-platform-backend:local
BACKEND_PORT=8080
FRONT_IMAGE=ai-platform-front:local
FRONT_PORT=80

JWT_SECRET=replace-with-a-long-base64-secret
AGENT_HEARTBEAT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
BOOTSTRAP_ADMIN_PASSWORD_HASH=replace-with-the-production-admin-password-hash
CORS_ALLOWED_ORIGINS=http://localhost
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
