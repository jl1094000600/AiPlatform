# Local Spring Boot development settings.
# Copy to .env and replace every secret before starting the backend.
DB_URL=jdbc:mysql://localhost:3306/ai_platform?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=replace-with-your-local-mysql-password

JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
AGENT_HEARTBEAT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
BOOTSTRAP_ADMIN_PASSWORD_HASH=replace-with-a-64-character-sha256-password-hash

OPENAI_API_KEY=
ANTHROPIC_API_KEY=
